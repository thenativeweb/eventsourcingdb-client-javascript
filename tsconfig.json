{
	"compilerOptions": {
		"ignoreDeprecations": "6.0",
		"declaration": true,
		"lib": ["ES2023"],
		"module": "preserve",
		"moduleResolution": "bundler",
		"outDir": "dist",
		"resolveJsonModule": true,
		"strict": true,
		"target": "ES2023",
		"types": ["node"]
	},
	"include": ["./src/**/*.ts"],
	"exclude": ["./dist"]
}
