; Pin exact dependency versions instead of ranges, so installs are reproducible
; and a caret/tilde range never silently pulls a newer (possibly compromised)
; release.
save-exact=true

; Supply-chain cooldown: refuse dependency versions published less than 7 days
; ago, the window in which most malicious releases are detected and yanked.
; Requires npm 11.10.0 or newer.
min-release-age=7

; Do not run dependency lifecycle scripts (preinstall/install/postinstall) on
; install; these are a common supply-chain attack vector and none of our
; dependencies need them.
ignore-scripts=true
