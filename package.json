{
  "name": "eventsourcingdb",
  "version": "1.8.1",
  "description": "The official JavaScript client SDK for EventSourcingDB.",
  "author": {
    "name": "the native web GmbH",
    "email": "hello@thenativeweb.io"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "types": "./dist/index.d.cts",
  "dependencies": {
    "testcontainers": "12.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@types/node": "25.9.3",
    "get-port": "7.2.0",
    "tsdown": "0.22.3",
    "tsx": "4.22.5",
    "typescript": "6.0.3"
  },
  "scripts": {
    "analyze": "npx tsc --noEmit && npx biome check --error-on-warnings .",
    "build": "npx tsc --noEmit && npx tsdown --format cjs,esm --dts --minify --out-dir ./dist ./src/index.ts",
    "format": "npx biome check --write .",
    "qa": "npm run analyze && npm run test",
    "test": "node --test --import tsx \"./src/**/*.test.ts\""
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/thenativeweb/eventsourcingdb-client-javascript.git"
  },
  "license": "MIT",
  "keywords": [
    "eventsourcingdb",
    "esdb",
    "event",
    "events",
    "event sourcing",
    "event store",
    "cqrs"
  ]
}
